<Window x:Class="RemoteClient.Views.RemoteDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escritorio Remoto" WindowState="Maximized"
        WindowStyle="None" ResizeMode="NoResize"
        KeyDown="Window_KeyDown">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250" x:Name="SidePanel"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0" x:Name="ScreenImage"
               Stretch="Uniform" StretchDirection="Both"
               MouseMove="ScreenImage_MouseMove"
               MouseDown="ScreenImage_MouseDown"
               MouseUp="ScreenImage_MouseUp"
               MouseWheel="ScreenImage_MouseWheel"/>

        <Border Grid.Column="1" Background="#1a1a2e" Width="250" HorizontalAlignment="Right">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Chat" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>

                <ListBox Grid.Row="1" x:Name="ChatList" Background="#0f3460" Foreground="White"
                         BorderThickness="0" Margin="0,0,0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="{Binding Sender}" FontWeight="Bold" Foreground="#00d2ff"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#ddd"/>
                                <TextBlock Text="{Binding Time}" FontSize="10" Foreground="#888"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <TextBox x:Name="ChatInput" Height="25" Width="160" Background="#0f3460"
                             Foreground="White" BorderThickness="0"/>
                    <Button Content="Enviar" x:Name="ChatSendBtn" Height="25" Width="60" Click="ChatSend_Click"
                            Background="#00d2ff" Foreground="Black" BorderThickness="0"/>
                </StackPanel>

                <Button Grid.Row="3" Content="Enviar archivo..." Margin="0,5,0,0"
                        Background="#16213e" Foreground="White" BorderThickness="0"
                        Click="SendFile_Click"/>
            </Grid>
        </Border>

        <Border x:Name="TopBar" Height="40" VerticalAlignment="Top" Background="#1a1a2e" Opacity="0.9"
                IsHitTestVisible="True" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                <Button Content="Chat" x:Name="ToggleChatBtn" Click="ToggleChat_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,5,0"/>
                <Button Content="Desconectar" Click="Disconnect_Click"
                        Background="#e94560" Foreground="White" BorderThickness="0" Padding="10,5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
