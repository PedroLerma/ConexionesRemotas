<Window x:Class="RemoteClient.Views.ConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conexión Remota - Conectar" Height="380" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="CONEXIÓN REMOTA" Foreground="#1a1a2e" FontSize="22"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Ingresa el código y la contraseña que te proporcionaron"
                       Foreground="#666" FontSize="13" HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"/>

            <Border Background="#f0f0f0" CornerRadius="8" Padding="20" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Código de sesión" FontSize="12" Foreground="#888"/>
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="28" FontFamily="Consolas" HorizontalAlignment="Center"
                             MaxLength="7" Width="200" TextAlignment="Center"/>

                    <TextBlock Text="Contraseña maestra" FontSize="12" Foreground="#888"/>
                    <PasswordBox x:Name="PasswordInput" FontSize="18"
                                 HorizontalAlignment="Center" Width="250"
                                 PasswordChanged="PasswordInput_PasswordChanged"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Status}" Foreground="#666" FontSize="12"
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>

            <Button x:Name="ConnectBtn" Content="CONECTAR" Padding="30,12"
                    IsEnabled="{Binding CanConnect}"
                    Click="ConnectBtn_Click"
                    HorizontalAlignment="Center"
                    Background="#1a1a2e" Foreground="White"
                    FontWeight="Bold" FontSize="14"
                    BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#1a1a2e"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#16213e"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#ccc"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
